# AI Provider Keys (you supply these). Live mode activates when any key is set.
# Claude / Anthropic (either name works)
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
CLAUDE_MODEL=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# xAI Grok (either name works)
XAI_API_KEY=
GROK_API_KEY=
XAI_MODEL=grok-2-latest
GROK_MODEL=

# Hugging Face
HUGGINGFACE_API_KEY=
HF_API_KEY=
HUGGINGFACE_MODEL=HuggingFaceH4/zephyr-7b-beta

# Default AI Provider when multiple keys are set: claude | openai | grok | huggingface
DEFAULT_AI_PROVIDER=grok

# EternalSocial gateway shared secret (required). Must match the proxy GATEWAY_KEY.
# Sites authenticate only via X-Gateway-Key + X-Auth-* from the proxy (no local OIDC).
GATEWAY_KEY=

# Owner admin email (matches X-Auth-Email from gateway)
# Authorization__AdminEmail=you@example.com

# Optional path base when behind the gateway (e.g. /x)
PATH_BASE=

# Optional: ngrok for public HTTPS during local gateway testing
NGROK_AUTHTOKEN=

# LiteDB path inside container
LITEDB_PATH=/app/data/eternalx.db
