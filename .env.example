# AI Provider Keys (you supply these)
CLAUDE_API_KEY=
OPENAI_API_KEY=
GROK_API_KEY=
HUGGINGFACE_API_KEY=

# Default AI Provider (claude, openai, grok, huggingface)
DEFAULT_AI_PROVIDER=claude

# OpenID Connect - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenID Connect - Microsoft (Entra ID)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# OpenID Connect - GitHub
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: ngrok for public HTTPS during local dev
NGROK_AUTHTOKEN=

# LiteDB path inside container
LITEDB_PATH=/app/data/eternalx.db