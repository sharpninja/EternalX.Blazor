@page "/admin"
@inject FeedApiClient Api

<PageTitle>Admin / EternalX</PageTitle>

<main class="content admin">
    @if (_me is null)
    {
        <p class="hint center">Checking access...</p>
    }
    else if (!_me.IsAdmin)
    {
        <p class="hint center">Forbidden. Owner only. Use the Admin link in the left sidebar when signed in as the configured owner.</p>
    }
    else
    {
        <h2 class="admin-h">Admin</h2>
        <p class="hint">Owner tools for EternalX feed, AI agents, and roster.</p>

        @if (_stats is not null)
        {
            <ul class="stats">
                <li>Posts: @_stats.PostCount</li>
                <li>Replies: @_stats.ReplyCount</li>
                <li>Figures: @_stats.EnabledFigures / @_stats.FigureCount</li>
                <li>Auto-reply: @(_stats.AutoReplyPaused ? "paused" : "running")</li>
            </ul>
        }

        <section class="admin-section">
            <h3 class="admin-sub">Engagement by personality</h3>
            <p class="hint">
                Ranked by score: likes + 2×reshares + replies on their posts + @@mentions.
                Sample size: @(_engagement?.PostSampleSize ?? 0) posts.
            </p>
            <div class="admin-actions">
                <button class="pill" @onclick="RefreshEngagement" disabled="@_busy">Refresh ranking</button>
            </div>
            @if (_personalities is null)
            {
                <p class="hint">Loading engagement...</p>
            }
            else if (_personalities.Count == 0)
            {
                <p class="hint">No personalities in roster.</p>
            }
            else
            {
                <div class="eng-table-wrap">
                    <table class="eng-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Personality</th>
                                <th>Score</th>
                                <th title="Hearts on their posts and replies">♥</th>
                                <th title="Quote-reshares of their posts">↻</th>
                                <th title="Replies under their posts">💬</th>
                                <th title="Mentions of their name">@@</th>
                                <th>Posts</th>
                                <th>Replies</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var rank = 0;
                            }
                            @foreach (var row in _personalities)
                            {
                                rank++;
                                <tr class="@(row.Enabled ? "" : "eng-disabled")">
                                    <td>@rank</td>
                                    <td class="eng-name">
                                        @row.Name
                                        @if (!row.Enabled)
                                        {
                                            <span class="agent-pill off">benched</span>
                                        }
                                    </td>
                                    <td class="eng-score">@row.EngagementScore</td>
                                    <td>@row.LikesReceived</td>
                                    <td>@row.ResharesReceived</td>
                                    <td>@row.RepliesReceived</td>
                                    <td>@row.MentionsReceived</td>
                                    <td>@row.PostsAuthored</td>
                                    <td>@row.RepliesAuthored</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="admin-section">
            <h3 class="admin-sub">AI agents</h3>
            <p class="hint">
                Disable an agent to stop using it without removing its API key from Octopus.
                Keys stay in the environment; only selection is toggled.
            </p>
            @if (_agents is null)
            {
                <p class="hint">Loading agents...</p>
            }
            else if (_agents.Count == 0)
            {
                <p class="hint">No providers registered.</p>
            }
            else
            {
                <p class="hint">Default provider: <strong>@_defaultProvider</strong></p>
                <ul class="agent-list">
                    @foreach (var agent in _agents)
                    {
                        <li class="agent-row">
                            <div class="agent-meta">
                                <span class="agent-name">@agent.Name</span>
                                <span class="agent-flags">
                                    @if (agent.HasApiKey)
                                    {
                                        <span class="agent-pill key">key</span>
                                    }
                                    else
                                    {
                                        <span class="agent-pill nokey">no key</span>
                                    }
                                    @if (agent.Active)
                                    {
                                        <span class="agent-pill active">active</span>
                                    }
                                    else if (agent.Enabled)
                                    {
                                        <span class="agent-pill idle">enabled</span>
                                    }
                                    else
                                    {
                                        <span class="agent-pill off">disabled</span>
                                    }
                                    @if (string.Equals(agent.Name, _defaultProvider, StringComparison.OrdinalIgnoreCase))
                                    {
                                        <span class="agent-pill def">default</span>
                                    }
                                </span>
                            </div>
                            <div class="agent-actions">
                                @if (agent.Enabled)
                                {
                                    <button class="pill" @onclick="() => DisableAgent(agent.Name)" disabled="@_busy">Disable</button>
                                }
                                else
                                {
                                    <button class="pill primary" @onclick="() => EnableAgent(agent.Name)" disabled="@(_busy || !agent.HasApiKey)" title="@(agent.HasApiKey ? "" : "No API key in environment")">
                                        Enable
                                    </button>
                                }
                                <button class="pill" @onclick="() => SetDefault(agent.Name)" disabled="@(_busy || !agent.HasApiKey)">
                                    Set default
                                </button>
                            </div>
                        </li>
                    }
                </ul>
            }
        </section>

        <section class="admin-section">
            <h3 class="admin-sub">Feed controls</h3>
            <div class="admin-actions">
                <button class="pill" @onclick="Pause">Pause auto-reply</button>
                <button class="pill" @onclick="Resume">Resume auto-reply</button>
                <button class="pill" @onclick="Seed">Re-seed roster</button>
                <button class="pill" @onclick="Export">Export JSON</button>
                <button class="pill danger" @onclick="ClearFeed">Clear feed</button>
            </div>
        </section>

        <p class="status">@_status</p>
    }
</main>

@code {
    private MeDto? _me;
    private AdminStatsDto? _stats;
    private List<AgentDto> _agents = new();
    private PersonalityEngagementReportDto? _engagement;
    private List<PersonalityEngagementDto>? _personalities;
    private string _defaultProvider = "grok";
    private string _status = "";
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        try { _me = await Api.GetMeAsync(); } catch { _me = new MeDto(false, null, null, null, false, false, true); }
        if (_me is { IsAdmin: true })
        {
            await RefreshStats();
            await RefreshAgents();
            await RefreshEngagement();
        }
    }

    private async Task RefreshStats()
    {
        try { _stats = await Api.GetAdminStatsAsync(); }
        catch { _status = "Could not load stats."; }
    }

    private async Task RefreshAgents()
    {
        try
        {
            var pack = await Api.GetAdminAgentsAsync();
            if (pack is not null)
            {
                _agents = pack.Agents ?? new();
                _defaultProvider = pack.DefaultProvider ?? "grok";
            }
        }
        catch { _status = "Could not load agents."; }
    }

    private async Task RefreshEngagement()
    {
        try
        {
            _engagement = await Api.GetPersonalityEngagementAsync();
            _personalities = _engagement?.Personalities ?? new();
            _status = _engagement is null
                ? "Could not load personality engagement."
                : $"Engagement ranked over {_engagement.PostSampleSize} posts.";
        }
        catch
        {
            _personalities = new();
            _status = "Could not load personality engagement.";
        }
    }

    private async Task EnableAgent(string name)
    {
        _busy = true;
        var r = await Api.EnableAgentAsync(name);
        _status = r.IsSuccessStatusCode ? $"Enabled {name}." : $"Failed to enable {name}.";
        await RefreshAgents();
        _busy = false;
    }

    private async Task DisableAgent(string name)
    {
        _busy = true;
        var r = await Api.DisableAgentAsync(name);
        _status = r.IsSuccessStatusCode ? $"Disabled {name} (API key kept)." : $"Failed to disable {name}.";
        await RefreshAgents();
        _busy = false;
    }

    private async Task SetDefault(string name)
    {
        _busy = true;
        var r = await Api.SetDefaultAgentAsync(name);
        _status = r.IsSuccessStatusCode ? $"Default provider set to {name}." : $"Failed to set default {name}.";
        await RefreshAgents();
        _busy = false;
    }

    private async Task Pause()
    {
        var r = await Api.PauseAutoReplyAsync();
        _status = r.IsSuccessStatusCode ? "Paused." : "Failed.";
        await RefreshStats();
    }

    private async Task Resume()
    {
        var r = await Api.ResumeAutoReplyAsync();
        _status = r.IsSuccessStatusCode ? "Resumed." : "Failed.";
        await RefreshStats();
    }

    private async Task Seed()
    {
        var r = await Api.SeedAsync();
        _status = r.IsSuccessStatusCode ? "Seed complete." : "Seed failed.";
        await RefreshStats();
    }

    private async Task ClearFeed()
    {
        var r = await Api.ClearFeedAsync();
        _status = r.IsSuccessStatusCode ? "Feed cleared (roster kept)." : "Clear failed.";
        await RefreshStats();
    }

    private async Task Export()
    {
        var r = await Api.ExportAsync();
        if (!r.IsSuccessStatusCode)
        {
            _status = "Export failed.";
            return;
        }
        var bytes = await r.Content.ReadAsByteArrayAsync();
        _status = $"Export ready ({bytes.Length} bytes). Use GET /api/admin/export to download.";
    }
}
