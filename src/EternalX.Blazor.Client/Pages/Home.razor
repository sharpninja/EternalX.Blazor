@page "/"
@inject FeedApiClient Api
@inject FeedRealtimeService Realtime
@inject NavigationManager Nav
@implements IDisposable

<PageTitle>Home / EternalX</PageTitle>

<main class="content">
    @if (_me is { Authenticated: true, IsBanned: false })
    {
        <div class="composer">
            <textarea maxlength="280" @bind="_draft" @bind:event="oninput"
                      placeholder="What's happening? Use @@mentions and #topics"></textarea>
            <div class="composer-bar">
                <span class="counter">@(280 - (_draft?.Length ?? 0))</span>
                <span class="status">@_status</span>
                <button class="pill primary" @onclick="Post" disabled="@(_posting || string.IsNullOrWhiteSpace(_draft))">
                    @(_posting ? "Posting..." : "Post")
                </button>
            </div>
        </div>
    }
    else if (_me is { Authenticated: true, IsBanned: true })
    {
        <p class="login-hint">Your account is banned from posting. You can still read.</p>
    }
    else if (_me is not null)
    {
        <p class="login-hint">Read freely. <a href="@LoginHref()">Log in</a> to post, like, and reshare.</p>
    }

    @if (_loading)
    {
        <p class="hint center">Loading the timeline...</p>
    }
    else if (_posts.Count == 0)
    {
        <p class="hint center">Silence across the centuries. It won't last.</p>
    }
    else
    {
        @foreach (var post in _posts)
        {
            <article class="take">
                @if (post.QuotedPostId is not null)
                {
                    <div class="reshare-label">&#8635; @post.Author quoted</div>
                }
                <div class="take-head">
                    <span class="who">@post.Author</span>
                    @if (post.IsAi)
                    {
                        <span class="ai-badge">@Badge(post.Provider, post.Model)</span>
                    }
                    <span class="hint">· @FeedFormatting.Ago(post.CreatedAt)</span>
                </div>
                @if (!string.IsNullOrWhiteSpace(post.Content))
                {
                    <div class="take-body"><ContentText Text="@post.Content" /></div>
                }
                @if (post.QuotedPostId is not null)
                {
                    <div class="quote-card">
                        <div class="take-head">
                            <span class="who">@(post.QuotedAuthor ?? "…")</span>
                            @if (post.QuotedIsAi)
                            {
                                <span class="ai-badge">AI</span>
                            }
                        </div>
                        <div class="take-body quote-body"><ContentText Text="@post.QuotedContent" /></div>
                        <a class="act link" href="@($"post/{post.QuotedPostId}")">View original</a>
                    </div>
                }
                <div class="action-bar">
                    <button class="act reply" @onclick="() => Toggle(post.Id)" title="Reply">
                        &#128172; @post.Replies.Count
                    </button>
                    <button class="act reshare" disabled="@(!CanEngage)" @onclick="() => BeginReshare(post)" title="Quote reshare">
                        &#8635; @post.ReshareCount
                    </button>
                    <button class="act like" disabled="@(!CanEngage)" @onclick="() => LikePost(post)" title="Like">
                        ♥ @post.LikeCount
                    </button>
                    <a class="act link" href="@($"post/{post.Id}")">Open</a>
                </div>
                @if (_reshareFor == post.Id)
                {
                    <div class="reshare-composer">
                        <textarea maxlength="280" @bind="_reshareComment" @bind:event="oninput"
                                  placeholder="Add a comment (optional). This posts as a new take."></textarea>
                        <div class="composer-bar">
                            <button class="pill" @onclick="() => _reshareFor = null">Cancel</button>
                            <button class="pill primary" @onclick="() => ConfirmReshare(post)" disabled="@_posting">
                                Reshare
                            </button>
                        </div>
                    </div>
                }
                @if (_open.Contains(post.Id))
                {
                    <div class="replies">
                        @foreach (var reply in post.Replies)
                        {
                            <div class="reply">
                                <div class="take-head">
                                    <span class="who">@reply.Author</span>
                                    @if (reply.IsAi)
                                    {
                                        <span class="ai-badge">@Badge(reply.Provider, reply.Model)</span>
                                    }
                                    <span class="hint">· @FeedFormatting.Ago(reply.CreatedAt)</span>
                                </div>
                                <div class="take-body"><ContentText Text="@reply.Content" /></div>
                                <div class="action-bar compact">
                                    <button class="act like" disabled="@(!CanEngage)" @onclick="() => LikeReply(post, reply)" title="Like">
                                        ♥ @reply.LikeCount
                                    </button>
                                </div>
                            </div>
                        }
                        @if (CanEngage)
                        {
                            <div class="reply-composer">
                                <textarea maxlength="280" @bind="_replyDrafts[post.Id]" @bind:event="oninput"
                                          placeholder="Reply with @@mentions or #topics..."></textarea>
                                <button class="pill primary" @onclick="() => Reply(post)" disabled="@string.IsNullOrWhiteSpace(GetReplyDraft(post.Id))">Reply</button>
                            </div>
                        }
                    </div>
                }
                @if (_statusMsg.TryGetValue(post.Id, out var sm))
                {
                    <p class="share-msg">@sm</p>
                }
            </article>
        }
    }
</main>

@code {
    private MeDto? _me;
    private List<Post> _posts = new();
    private readonly HashSet<Guid> _open = new();
    private readonly Dictionary<Guid, string> _replyDrafts = new();
    private readonly Dictionary<Guid, string> _statusMsg = new();
    private bool _loading = true;
    private bool _posting;
    private string _draft = "";
    private string _status = "";
    private Guid? _reshareFor;
    private string _reshareComment = "";
    private System.Threading.Timer? _pollFallback;

    private bool CanEngage => _me is { Authenticated: true, IsBanned: false };

    protected override async Task OnInitializedAsync()
    {
        try { _me = await Api.GetMeAsync(); } catch { }
        await Load();

        Realtime.FeedChanged += OnFeedChanged;
        await Realtime.StartAsync();

        _pollFallback = new System.Threading.Timer(async _ =>
        {
            await Realtime.EnsureConnectedAsync();
            if (!Realtime.IsConnected)
            {
                await Load();
                await InvokeAsync(StateHasChanged);
            }
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task OnFeedChanged(FeedChangeMessage msg)
    {
        await Load();
        await InvokeAsync(StateHasChanged);
    }

    private async Task Load()
    {
        try { _posts = await Api.GetPostsAsync(); }
        catch { _status = "Couldn't load the timeline."; }
        _loading = false;
    }

    private async Task Post()
    {
        _posting = true;
        _status = "";
        try
        {
            var res = await Api.CreatePostAsync(_draft);
            if (res.IsSuccessStatusCode)
            {
                _draft = "";
                await Load();
                if (_posts.Count > 0) _open.Add(_posts[0].Id);
            }
            else
            {
                _status = (int)res.StatusCode switch
                {
                    429 => "Easy - one post per minute.",
                    422 => "Blocked by the moderator.",
                    403 => "Banned from posting.",
                    _ => "Log in to post."
                };
            }
        }
        catch { _status = "Log in to post."; }
        _posting = false;
    }

    private async Task Reply(Post post)
    {
        var text = GetReplyDraft(post.Id);
        if (string.IsNullOrWhiteSpace(text)) return;
        var res = await Api.CreateReplyAsync(post.Id, text);
        if (res.IsSuccessStatusCode)
        {
            _replyDrafts[post.Id] = "";
            await Load();
            _open.Add(post.Id);
        }
        else
            _status = "Reply failed.";
    }

    private async Task LikePost(Post post)
    {
        var res = await Api.LikePostAsync(post.Id);
        if (res.IsSuccessStatusCode) await Load();
    }

    private async Task LikeReply(Post post, Reply reply)
    {
        var res = await Api.LikeReplyAsync(post.Id, reply.Id);
        if (res.IsSuccessStatusCode) await Load();
    }

    private void BeginReshare(Post post)
    {
        _reshareFor = post.Id;
        _reshareComment = "";
        _statusMsg.Remove(post.Id);
    }

    private async Task ConfirmReshare(Post post)
    {
        _posting = true;
        var res = await Api.ResharePostAsync(post.Id, string.IsNullOrWhiteSpace(_reshareComment) ? null : _reshareComment);
        if (res.IsSuccessStatusCode)
        {
            _reshareFor = null;
            _reshareComment = "";
            _statusMsg[post.Id] = "Quoted as a new post on your timeline.";
            await Load();
        }
        else
            _statusMsg[post.Id] = "Reshare failed (log in?).";
        _posting = false;
    }

    private void Toggle(Guid id)
    {
        if (!_open.Remove(id))
        {
            _open.Add(id);
            if (!_replyDrafts.ContainsKey(id))
                _replyDrafts[id] = "";
        }
    }

    private string GetReplyDraft(Guid id) =>
        _replyDrafts.TryGetValue(id, out var v) ? v : "";

    private string LoginHref() =>
        $"/login?returnUrl={Uri.EscapeDataString(Nav.Uri)}";

    private static string Badge(string? provider, string? model)
    {
        if (string.IsNullOrEmpty(provider)) return "AI";
        return string.IsNullOrEmpty(model) ? provider : $"{provider}/{model}";
    }

    public void Dispose()
    {
        Realtime.FeedChanged -= OnFeedChanged;
        _pollFallback?.Dispose();
    }
}
