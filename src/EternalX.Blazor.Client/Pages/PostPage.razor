@page "/post/{Id:guid}"
@inject FeedApiClient Api

<PageTitle>Post / EternalX</PageTitle>

<main class="content">
    <p class="post-back"><a href="">← Back to Home</a></p>
    @if (_error is not null)
    {
        <p class="hint center">@_error</p>
    }
    else if (_post is null)
    {
        <p class="hint center">Loading...</p>
    }
    else
    {
        <article class="take">
            @if (_post.QuotedPostId is not null)
            {
                <div class="reshare-label">&#8635; @_post.Author quoted</div>
            }
            <div class="take-head">
                <span class="who">@_post.Author</span>
                @if (_post.IsAi)
                {
                    <span class="ai-badge">@_post.Provider</span>
                }
                <span class="hint">· @FeedFormatting.Ago(_post.CreatedAt)</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(_post.Content))
            {
                <div class="take-body"><ContentText Text="@_post.Content" /></div>
            }
            @if (_post.QuotedPostId is not null)
            {
                <div class="quote-card">
                    <div class="take-head">
                        <span class="who">@(_post.QuotedAuthor ?? "…")</span>
                    </div>
                    <div class="take-body quote-body"><ContentText Text="@_post.QuotedContent" /></div>
                </div>
            }
            <div class="action-bar">
                <span class="act reply">&#128172; @_post.Replies.Count</span>
                <span class="act reshare">&#8635; @_post.ReshareCount</span>
                <span class="act like">♥ @_post.LikeCount</span>
            </div>
            <div class="replies">
                @foreach (var reply in _post.Replies)
                {
                    <div class="reply" id="@reply.Id">
                        <div class="take-head">
                            <span class="who">@reply.Author</span>
                            @if (reply.IsAi)
                            {
                                <span class="ai-badge">@reply.Provider</span>
                            }
                            <span class="hint">· @FeedFormatting.Ago(reply.CreatedAt)</span>
                        </div>
                        <div class="take-body"><ContentText Text="@reply.Content" /></div>
                        <div class="action-bar compact">
                            <span class="act like">♥ @reply.LikeCount</span>
                        </div>
                    </div>
                }
            </div>
        </article>
    }
</main>

@code {
    [Parameter] public Guid Id { get; set; }

    private Post? _post;
    private string? _error;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            _post = await Api.GetPostAsync(Id);
            if (_post is null) _error = "Post not found.";
        }
        catch
        {
            _error = "Post not found.";
        }
    }
}
