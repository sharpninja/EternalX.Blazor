@page "/hashtag/{Tag}"
@inject FeedApiClient Api
@inject NavigationManager Nav

<PageTitle>#@DisplayTag / EternalX</PageTitle>

<main class="timeline">
    <header class="timeline-header detail-header">
        <a class="back-btn" href="" title="Back to Home">←</a>
        <div class="hashtag-header-text">
            <h1 class="timeline-title">#@DisplayTag</h1>
            @if (!_loading)
            {
                <span class="hint hashtag-count">@_posts.Count post@(_posts.Count == 1 ? "" : "s")</span>
            }
        </div>
    </header>

    @if (_me is { Authenticated: true, IsBanned: false })
    {
        <div class="composer">
            <div class="tweet-row">
                <Avatar Author="@(_me.Name ?? "me")" CssClass="avatar-lg" />
                <div class="tweet-main">
                    <textarea maxlength="280" @bind="_draft" @bind:event="oninput"
                              placeholder="@($"Post with #{DisplayTag}")" rows="3"></textarea>
                    <div class="composer-bar">
                        <span class="composer-hint">Tagged with #@DisplayTag</span>
                        <span class="counter @(_draft.Length > 260 ? "counter-warn" : "")">@(280 - _draft.Length)</span>
                        <button type="button" class="btn-post" @onclick="Post"
                                disabled="@(_posting || string.IsNullOrWhiteSpace(_draft))">
                            @(_posting ? "…" : "Post")
                        </button>
                    </div>
                    @if (!string.IsNullOrEmpty(_status))
                    {
                        <p class="status">@_status</p>
                    }
                </div>
            </div>
        </div>
    }

    @if (_error is not null)
    {
        <p class="hint center">@_error</p>
    }
    else if (_loading)
    {
        <p class="hint center">Loading #@DisplayTag…</p>
    }
    else if (_posts.Count == 0)
    {
        <p class="hint center empty-feed">No posts with #@DisplayTag yet. Be the first.</p>
    }
    else
    {
        @foreach (var post in _posts)
        {
            <article class="tweet" @key="post.Id">
                @if (post.QuotedPostId is not null)
                {
                    <div class="tweet-context">
                        <ActionIcon Kind="reshare" />
                        <span>@FeedFormatting.MetaDisplayName(post.Author, post.AuthorUsername) quoted</span>
                    </div>
                }

                <div class="tweet-row">
                    <a class="tweet-avatar-link" href="@($"post/{post.Id}")" tabindex="-1">
                        <Avatar Author="@post.Author" Username="@post.AuthorUsername" />
                    </a>
                    <div class="tweet-main">
                        <div class="tweet-head-line">
                            <a class="tweet-identity" href="@($"post/{post.Id}")">
                                <TweetMeta Author="@post.Author" Username="@post.AuthorUsername"
                                           CreatedAt="@post.CreatedAt"
                                           IsAi="@post.IsAi" Provider="@post.Provider" Model="@post.Model" />
                            </a>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(post.Content))
                        {
                            <div class="tweet-body"><ContentText Text="@post.Content" /></div>
                        }

                        @if (post.QuotedPostId is not null)
                        {
                            <a class="quote-card" href="@($"post/{post.QuotedPostId}")">
                                <div class="tweet-row quote-inner">
                                    <Avatar Author="@(post.QuotedAuthor ?? "?")" Username="@post.QuotedAuthorUsername" CssClass="avatar-sm" />
                                    <div class="tweet-main">
                                        <TweetMeta Author="@post.QuotedAuthor" Username="@post.QuotedAuthorUsername"
                                                   CreatedAt="@post.CreatedAt" IsAi="@post.QuotedIsAi" />
                                        <div class="tweet-body quote-body">
                                            <ContentText Text="@(post.QuotedContent ?? "")" />
                                        </div>
                                    </div>
                                </div>
                            </a>
                        }

                        <div class="action-bar">
                            <button type="button" class="act act-reply" title="Reply" @onclick="() => Toggle(post.Id)">
                                <span class="act-btn"><ActionIcon Kind="reply" /></span>
                                <span class="act-count">@FeedFormatting.CountLabel(post.Replies.Count)</span>
                            </button>
                            <button type="button" class="act act-reshare" title="Repost / quote"
                                    disabled="@(!CanEngage)" @onclick="() => BeginReshare(post)">
                                <span class="act-btn"><ActionIcon Kind="reshare" /></span>
                                <span class="act-count">@FeedFormatting.CountLabel(post.ReshareCount)</span>
                            </button>
                            <button type="button" class="act act-like" title="Like"
                                    disabled="@(!CanEngage)" @onclick="() => LikePost(post)">
                                <span class="act-btn"><ActionIcon Kind="like" /></span>
                                <span class="act-count">@FeedFormatting.CountLabel(post.LikeCount)</span>
                            </button>
                        </div>

                        @if (_reshareFor == post.Id)
                        {
                            <div class="inline-composer">
                                <textarea maxlength="280" @bind="_reshareComment" @bind:event="oninput"
                                          placeholder="Add a comment (optional)"></textarea>
                                <div class="composer-bar">
                                    <button type="button" class="pill" @onclick="() => _reshareFor = null">Cancel</button>
                                    <button type="button" class="btn-post" @onclick="() => ConfirmReshare(post)" disabled="@_posting">
                                        Repost
                                    </button>
                                </div>
                            </div>
                        }

                        @if (_open.Contains(post.Id))
                        {
                            <div class="thread-inline">
                                @foreach (var reply in post.Replies.OrderBy(r => r.CreatedAt))
                                {
                                    <div class="tweet tweet-reply" @key="reply.Id">
                                        <div class="tweet-row">
                                            <Avatar Author="@reply.Author" Username="@reply.AuthorUsername" CssClass="avatar-sm" />
                                            <div class="tweet-main">
                                                <TweetMeta Author="@reply.Author" Username="@reply.AuthorUsername"
                                                           CreatedAt="@reply.CreatedAt"
                                                           IsAi="@reply.IsAi" Provider="@reply.Provider" Model="@reply.Model" />
                                                <div class="tweet-body"><ContentText Text="@reply.Content" /></div>
                                                <div class="action-bar compact">
                                                    <button type="button" class="act act-like" title="Like"
                                                            disabled="@(!CanEngage)" @onclick="() => LikeReply(post, reply)">
                                                        <span class="act-btn"><ActionIcon Kind="like" /></span>
                                                        <span class="act-count">@FeedFormatting.CountLabel(reply.LikeCount)</span>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                                @if (CanEngage)
                                {
                                    <div class="inline-composer reply-box">
                                        <textarea maxlength="280" @bind="_replyDrafts[post.Id]" @bind:event="oninput"
                                                  placeholder="Post your reply"></textarea>
                                        <div class="composer-bar">
                                            <button type="button" class="btn-post"
                                                    @onclick="() => Reply(post)"
                                                    disabled="@string.IsNullOrWhiteSpace(GetReplyDraft(post.Id))">
                                                Reply
                                            </button>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </article>
        }
    }
</main>

@code {
    [Parameter] public string Tag { get; set; } = "";

    private MeDto? _me;
    private List<Post> _posts = new();
    private readonly HashSet<Guid> _open = new();
    private readonly Dictionary<Guid, string> _replyDrafts = new();
    private bool _loading = true;
    private bool _posting;
    private string _draft = "";
    private string _status = "";
    private string? _error;
    private Guid? _reshareFor;
    private string _reshareComment = "";

    private string DisplayTag => ContentTags.NormalizeHashtag(Tag);
    private bool CanEngage => _me is { Authenticated: true, IsBanned: false };

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _error = null;
        _posts = new();

        if (string.IsNullOrEmpty(DisplayTag))
        {
            _error = "Invalid hashtag.";
            _loading = false;
            return;
        }

        // Prefill composer so new posts land on this tag feed.
        if (string.IsNullOrWhiteSpace(_draft))
            _draft = $"#{DisplayTag} ";

        try { _me = await Api.GetMeAsync(); } catch { }

        try
        {
            var feed = await Api.GetHashtagFeedAsync(DisplayTag);
            _posts = feed?.Posts ?? new List<Post>();
        }
        catch
        {
            _error = "Couldn't load this hashtag.";
        }

        _loading = false;
    }

    private async Task Post()
    {
        _posting = true;
        _status = "";
        try
        {
            var text = _draft.Trim();
            // Ensure the active tag is present so the post stays on this feed.
            if (!ContentTags.PostMatchesHashtag(new Post { Content = text }, DisplayTag))
                text = $"{text} #{DisplayTag}".Trim();

            var res = await Api.CreatePostAsync(text);
            if (res.IsSuccessStatusCode)
            {
                _draft = $"#{DisplayTag} ";
                await Reload();
            }
            else
            {
                _status = (int)res.StatusCode switch
                {
                    429 => "Easy - one post per minute.",
                    422 => "Blocked by the moderator.",
                    403 => "Banned from posting.",
                    _ => "Log in to post."
                };
            }
        }
        catch { _status = "Log in to post."; }
        _posting = false;
    }

    private async Task Reload()
    {
        try
        {
            var feed = await Api.GetHashtagFeedAsync(DisplayTag);
            _posts = feed?.Posts ?? new List<Post>();
        }
        catch { /* keep existing */ }
    }

    private async Task Reply(Post post)
    {
        var text = GetReplyDraft(post.Id);
        if (string.IsNullOrWhiteSpace(text)) return;
        var res = await Api.CreateReplyAsync(post.Id, text);
        if (res.IsSuccessStatusCode)
        {
            _replyDrafts[post.Id] = "";
            await Reload();
            _open.Add(post.Id);
        }
    }

    private async Task LikePost(Post post)
    {
        var res = await Api.LikePostAsync(post.Id);
        if (res.IsSuccessStatusCode) await Reload();
    }

    private async Task LikeReply(Post post, Reply reply)
    {
        var res = await Api.LikeReplyAsync(post.Id, reply.Id);
        if (res.IsSuccessStatusCode) await Reload();
    }

    private void BeginReshare(Post post)
    {
        _reshareFor = post.Id;
        _reshareComment = "";
    }

    private async Task ConfirmReshare(Post post)
    {
        _posting = true;
        var res = await Api.ResharePostAsync(post.Id, string.IsNullOrWhiteSpace(_reshareComment) ? null : _reshareComment);
        if (res.IsSuccessStatusCode)
        {
            _reshareFor = null;
            _reshareComment = "";
            await Reload();
        }
        _posting = false;
    }

    private void Toggle(Guid id)
    {
        if (!_open.Remove(id))
        {
            _open.Add(id);
            if (!_replyDrafts.ContainsKey(id))
                _replyDrafts[id] = "";
        }
    }

    private string GetReplyDraft(Guid id) =>
        _replyDrafts.TryGetValue(id, out var v) ? v : "";
}
