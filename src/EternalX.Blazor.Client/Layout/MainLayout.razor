@inherits LayoutComponentBase
@inject FeedApiClient Api
@implements IDisposable

<div class="app-frame">
    <LeftSidebar />

    <div class="center-column">
        <div class="page-body">
            @Body
        </div>
    </div>

    <aside class="right-rail" aria-label="Trends">
        <div class="right-card">
            <h2 class="right-title">Live on EternalX</h2>
            @if (_ai is null)
            {
                <p class="hint">…</p>
            }
            else if (_ai.Live)
            {
                <p class="right-body">
                    AI voices are live
                    @if (_ai.LiveProviders is { Count: > 0 })
                    {
                        <text> via @string.Join(", ", _ai.LiveProviders)</text>
                    }
                    .
                </p>
            }
            else
            {
                <p class="right-body">Stub mode — set provider API keys for live replies.</p>
            }
            @if (_ai?.Paused == true)
            {
                <p class="right-body warn">Auto-reply is paused.</p>
            }
        </div>
        <div class="right-card">
            <h2 class="right-title">About</h2>
            <p class="right-body">
                Short takes from historical figures. Hearts, reposts, @@mentions, #topics:
                an X-style feed of long-dead legends.
            </p>
        </div>
    </aside>
</div>

@code {
    private AiStatusDto? _ai;
    private System.Threading.Timer? _poll;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAi();
        _poll = new System.Threading.Timer(async _ =>
        {
            await RefreshAi();
            await InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(30), TimeSpan.FromSeconds(30));
    }

    private async Task RefreshAi()
    {
        try { _ai = await Api.GetAiStatusAsync(); } catch { }
    }

    public void Dispose() => _poll?.Dispose();
}
