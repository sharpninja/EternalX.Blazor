@inject FeedApiClient Api
@inject NavigationManager Nav
@implements IDisposable

<aside class="left-rail" aria-label="Primary">
    <a class="rail-logo" href="" title="EternalX Home">
        <span class="brand-x">&#120143;</span>
    </a>

    <nav class="rail-nav">
        <NavLink class="rail-item" href="" Match="NavLinkMatch.All">
            <span class="rail-icon" aria-hidden="true">⌂</span>
            <span class="rail-label">Home</span>
        </NavLink>

        @if (_me is { IsAdmin: true })
        {
            <NavLink class="rail-item rail-admin" href="admin">
                <span class="rail-icon" aria-hidden="true">⚙</span>
                <span class="rail-label">Admin</span>
            </NavLink>
        }

        @if (_me is { Authenticated: true })
        {
            <a class="rail-item" href="/logout">
                <span class="rail-icon" aria-hidden="true">↪</span>
                <span class="rail-label">Log out</span>
            </a>
        }
        else if (_me is not null)
        {
            <a class="rail-item" href="@LoginHref()">
                <span class="rail-icon" aria-hidden="true">↪</span>
                <span class="rail-label">Log in</span>
            </a>
        }
    </nav>

    <div class="rail-footer">
        @if (_me is { Authenticated: true })
        {
            <div class="rail-user" title="@_me.Email">
                <Avatar Author="@(_me.Name ?? "me")" />
                <span class="rail-user-meta">
                    <span class="rail-user-name">@FeedFormatting.DisplayName(_me.Name ?? "Member")</span>
                    <span class="rail-user-handle">@FeedFormatting.AtHandle(_me.Name ?? "member")</span>
                    @if (_me.IsBanned)
                    {
                        <span class="ban-badge">banned</span>
                    }
                    else if (_me.IsAdmin)
                    {
                        <span class="rail-user-role">owner</span>
                    }
                </span>
            </div>
        }
        else if (_me is not null)
        {
            <a class="rail-cta" href="@LoginHref()">Log in</a>
        }
    </div>
</aside>

@code {
    private MeDto? _me;

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;
        await RefreshMe();
    }

    private async void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        await RefreshMe();
        await InvokeAsync(StateHasChanged);
    }

    private async Task RefreshMe()
    {
        try { _me = await Api.GetMeAsync(); }
        catch { _me = new MeDto(false, null, null, null, false, false, true); }
    }

    private string LoginHref() =>
        $"/login?returnUrl={Uri.EscapeDataString(Nav.Uri)}";

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;
}
